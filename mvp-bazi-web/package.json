{
  "name": "mingyi-bazi-mvp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "test": "vitest run",
    "db:setup": "node scripts/db-setup.mjs",
    "db:setup:dry": "node scripts/db-setup.mjs --dry-run",
    "preflight": "node scripts/preflight.mjs",
    "preflight:smoke": "node scripts/preflight.test.mjs",
    "verify": "npm test && npm run build && npm run db:setup:dry && npm run preflight:smoke"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "lunar-typescript": "1.8.6",
    "next": "16.2.10",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "stripe": "22.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
